# Copie este arquivo para .env e preencha com seus dados reais.
# O arquivo .env NUNCA é enviado ao git (já está no .gitignore).

# URL do seu projeto Supabase (painel → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave de serviço — service_role key (painel → Settings → API → service_role)
# ATENÇÃO: esta chave ignora Row Level Security — nunca exponha ao público
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# UUID do escritório criado pelo schema.sql — copie daqui após rodar o schema
ESCRITORIO_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
